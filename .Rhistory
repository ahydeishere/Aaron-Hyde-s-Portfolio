pacman::p_load(tidyverse, readr, readxl, downloader, rio, plotly, knitr, pander, ggthemes, ggrepel, directlabels, gapminder, dplyr, nycflights13, Lahman, priceR, riem, USAboundaries, USAboundariesData, sf, stringr, stringi, reticulate, maps)
# 2. Get US Map data
us_map <- map_data("state")
nfl_geom_data <- read_csv("C:/Users/aaron/OneDrive/Desktop/nfl_data/team_stats_geocoded.csv")
# 1. Load the geocoded data
nfl_geom_data <- read_csv("C:/Users/aaron/OneDrive/Desktop/nfl_data/team_stats_geocoded.csv")
# 2. Get US Map data
us_map <- map_data("state")
# 3. Filter for specific years to show movement (e.g., 2003 vs 2023)
# Or you can animate this using gganimate
map_plot <- ggplot() +
# Draw the US Map background
geom_polygon(data = us_map, aes(x = long, y = lat, group = group),
fill = "grey95", color = "white") +
# Plot the team locations
geom_point(data = nfl_geom_data %>% filter(year %in% c(2003, 2023)),
aes(x = long, y = lat, color = team),
size = 3, alpha = 0.7) +
# Add labels to the teams
geom_text_repel(data = nfl_geom_data %>% filter(year %in% c(2003, 2023)),
aes(x = long, y = lat, label = team),
size = 2.5, max.overlaps = 20) +
# Facet by year to see the movement clearly
facet_wrap(~year) +
coord_fixed(1.3) + # Correct aspect ratio for US map
theme_minimal() +
labs(title = "NFL Team Locations: 2003 vs 2023",
subtitle = "Visualizing team relocations and name changes",
x = "Longitude", y = "Latitude") +
theme(legend.position = "none")
# Display the plot
print(map_plot)
# Display the plot
map_plot
# This is for visuals in future parts of the data set
team_colors <- c(
# NFC North
"Chicago Bears"            = "#0B162A", "Detroit Lions"            = "#0076B6", "Green Bay Packers"        = "#203731", "Minnesota Vikings"        = "#4F2683",
# NFC South
"Atlanta Falcons"          = "#A71930", "Carolina Panthers"        = "#0085CA", "New Orleans Saints"       = "#D3BC8D", "Tampa Bay Buccaneers"     = "#D50A0A",
# NFC East
"Dallas Cowboys"           = "#003594", "New York Giants"          = "#0B2265", "Philadelphia Eagles"      = "#004C54", "Washington Commanders"    = "#5A1414",
# NFC West
"Arizona Cardinals"        = "#97233F", "Los Angeles Rams"         = "#003594", "San Francisco 49ers"      = "#AA0000", "Seattle Seahawks"         = "#002244",
# AFC North
"Baltimore Ravens"         = "#241773", "Cincinnati Bengals"       = "#FB4F14", "Cleveland Browns"         = "#311D00", "Pittsburgh Steelers"      = "#FFB612",
# AFC South
"Houston Texans"           = "#03202F", "Indianapolis Colts"       = "#002C5F", "Jacksonville Jaguars"     = "#006778", "Tennessee Titans"         = "#0C2340",
# AFC East
"Buffalo Bills"            = "#00338D", "Miami Dolphins"           = "#008E97", "New England Patriots"     = "#002244", "New York Jets"            = "#125740",
# AFC West
"Denver Broncos"           = "#FB4F14", "Kansas City Chiefs"       = "#E31837", "Las Vegas Raiders"        = "#000000", "Los Angeles Chargers"     = "#0080C6"
)
specific_division <- function(division_name) {
team_specific <- nfl_data_cleaned %>%
filter(division == division_name)
division_graph <- ggplot(team_specific, aes(y = wins, x = year, color = team)) +
geom_line() +
scale_x_continuous(limits = c(NA, 2027), breaks = c(2000, 2005, 2010,2015,2020)) +
scale_y_continuous(breaks = c(2,4,6,8,10,12,14,16))+
scale_color_manual(values = team_colors) +
theme_classic() +
theme(
legend.position = "none",
plot.margin = margin(5, 90, 5, 5),
axis.line.y = element_line(color = "black", linewidth = 0.5),
axis.line.x = element_line(color = "black", linewidth = 0.5),
panel.grid.major.y = element_line(color = "gray80", linewidth = 0.3),
panel.grid.major.x = element_line(color = "gray80", linewidth = 0.3),
panel.grid.minor.y = element_line(color = "gray90", linewidth = 0.2)
) +
geom_text_repel(
data = team_specific %>% filter(year == max(year)),
aes(label = team),
size = 3,
nudge_x = 2,
direction = "y",
hjust = 0,
segment.size = 0.3
) +
coord_cartesian(clip = "off")+
labs(
title = division_name
)
return(division_graph)
}
specific_division("AFC North")
